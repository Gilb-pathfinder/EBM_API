<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{title || 'PLU Report - CIS'}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-size: 12pt; }
    body { font-family: 'Times New Roman', Arial, sans-serif; margin: 10pt; color: #000; }
    h1, h2 { text-align: center; margin: 0; }
    .header, .section, .footer { margin-top: 10pt; }
    .row { display: flex; justify-content: space-between; margin: 2pt 0; }
    .plu-table { width: 100%; border-collapse: collapse; margin-top: 10pt; }
    .plu-table th, .plu-table td { border: 1pt solid #000; padding: 4pt; text-align: left; }
    .plu-table th { background-color: #f2f2f2; }
    button#printBtn { display: block; margin: 10pt auto; padding: 5pt 10pt; font-size: 12pt; cursor: pointer; }
    @media print { button#printBtn { display: none; } }
  </style>
</head>
<body>
  <header>
      <h1>PLU Sales Report</h1>
      <p style="text-align:center;">Period: {{dateTime}}</p>
  </header>

  <button id="printBtn" onclick="window.print()">Print Report</button>

  <div class="header">
    <div class="row"><strong>Trade Name:</strong> <span>{{auth.user.taxPayerName}}</span></div>
    <div class="row"><strong>TIN:</strong> <span>{{auth.user.tin}}</span></div>
    <div class="row"><strong>MRC:</strong> <span>{{auth.user.mrc}}</span></div>
  </div>

  <div class="section">
    <table class="plu-table">
      <thead>
        <tr>
          <th>Item Code</th>
          <th>Item Name</th>
          <th style="text-align:right;">Quantity</th>
          <th style="text-align:right;">Unit Price (RWF)</th>
          <th style="text-align:right;">Total Amount (RWF)</th>
          <th style="text-align:center;">Tax Type</th>
          <th style="text-align:right;">Remaining Stock</th>
        </tr>
      </thead>
      <tbody>
        @each(item in pluSummaries)
        <tr>
          <td>{{item.code}}</td>
          <td>{{item.name}}</td>
          <td style="text-align:right;">{{item.quantity}}</td>
          <td style="text-align:right;">{{item.unitPrice != null ? item.unitPrice.toFixed(2) : 'N/A'}}</td>
          <td style="text-align:right;">{{item.totalAmount.toFixed(2)}}</td>
          <td style="text-align:center;">{{item.taxationType || 'N/A'}}</td>
          <td style="text-align:right;">{{item.remainingStock != null ? item.remainingStock : 'N/A'}}</td>
        </tr>
        @end
      </tbody>
    </table>
  </div>

  <div class="footer">
    <p style="text-align:center; font-size: 10pt; margin-top: 50px;">
      CIS v{{auth.user.cisApiVersion}}, power by RRA VSDC EBM {{auth.user.ebmApiVersion}}
      <br>
      <small style="font-size: 6pt">YB VSDC API - PLU REPORT</small>
    </p>
  </div>
</body>
</html>
