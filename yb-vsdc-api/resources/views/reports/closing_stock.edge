<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Closing Stock Report - CIS</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-size: 11pt; }
    body { font-family: 'Times New Roman', Arial, sans-serif; margin: 20pt; color: #000; }
    h1, h2 { text-align: center; margin: 0; }
    .header { margin-bottom: 12pt; }
    .header .row { display: flex; justify-content: space-between; margin: 2pt 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 10pt; }
    th, td { border: 1px solid #000; padding: 5pt; text-align: left; font-size: 10pt; }
    th { background: #f0f0f0; font-weight: bold; }
    td.qty { text-align: right; font-weight: bold; }
    td.zero { color: #c00; }
    .footer { margin-top: 30pt; text-align: center; font-size: 8pt; }
    button#printBtn { display: block; margin: 8pt auto; padding: 4pt 10pt; cursor: pointer; font-size: 11pt; }
    @media print { button#printBtn { display: none; } }
  </style>
</head>
<body>

  <header>
    @if(auth.user.image)
    <img src="{{appUrl}}{{ auth.user.image.url }}" loading="eager" style="max-height:60px;display:block;margin:0 auto 6pt;" />
    @elseif(auth.user.imageLink)
    <img src="{{ auth.user.imageLink }}" loading="eager" style="max-height:60px;display:block;margin:0 auto 6pt;" />
    @endif
    <h1>Closing Stock Report</h1>
  </header>

  <button id="printBtn" onclick="window.print()">Print Report</button>

  <div class="header">
    <div class="row"><strong>Trade Name:</strong> <span>{{auth.user.taxPayerName}}</span></div>
    <div class="row"><strong>TIN:</strong> <span>{{auth.user.tin}}</span></div>
    <div class="row"><strong>Stock as of:</strong> <span>{{dateAs}}</span></div>
    <div class="row"><strong>Generated:</strong> <span>{{dateTime}}</span></div>
    <div class="row"><strong>MRC:</strong> <span>{{auth.user.mrc}}</span></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Item Code</th>
        <th>Item Name</th>
        <th style="text-align:right;">Closing Qty (as of {{dateAs}})</th>
        <th style="text-align:right;">Current Qty (today)</th>
      </tr>
    </thead>
    <tbody>
      @each((row, index) in closingStocks)
      <tr>
        <td>{{index + 1}}</td>
        <td>{{row.itemCode}}</td>
        <td>{{row.name}}</td>
        <td class="qty {{row.closingQty === 0 ? 'zero' : ''}}">{{row.closingQty}}</td>
        <td class="qty">{{row.currentQty}}</td>
      </tr>
      @end
      @if(closingStocks.length === 0)
      <tr><td colspan="5" style="text-align:center;padding:12pt;">No stock records found.</td></tr>
      @endif
    </tbody>
  </table>

  <div class="footer">
    CIS v{{auth.user.cisApiVersion}}, powered by RRA VSDC EBM {{auth.user.ebmApiVersion}}
    <br><small>YB VSDC API — CLOSING STOCK REPORT (§7.31)</small>
  </div>

</body>
</html>
